{
  "$schema": "https://anthropic.com/claude-code/marketplace.schema.json",
  "description": "통합 개발 워크플로우, 외부 LLM 인프라, Git 자동화 등 Claude Code 플러그인 모음",
  "name": "kys-claude-plugin",
  "owner": {
    "name": "kys0213"
  },
  "plugins": [
    {
      "category": "productivity",
      "description": "통합 개발 워크플로우: 설계 → 리뷰 → 구현을 하나의 파이프라인으로 (멀티 LLM 지원)",
      "keywords": [
        "develop",
        "workflow",
        "design",
        "review",
        "planning",
        "multi-llm",
        "architecture"
      ],
      "name": "develop-workflow",
      "source": "./plugins/develop-workflow",
      "version": "0.6.1"
    },
    {
      "category": "integration",
      "description": "외부 LLM(OpenAI Codex, Google Gemini) 호출 인프라",
      "keywords": [
        "codex",
        "gemini",
        "external-llm"
      ],
      "name": "external-llm",
      "source": "./plugins/external-llm",
      "strict": false,
      "version": "0.8.0"
    },
    {
      "category": "productivity",
      "description": "Git 워크플로우 자동화 - 브랜치, 커밋, PR, 머지, 동기화, conflict 해결, Issue 관리",
      "keywords": [
        "git",
        "branch",
        "sync",
        "pr",
        "commit",
        "merge",
        "workflow",
        "conflict",
        "issue"
      ],
      "name": "git-utils",
      "source": "./plugins/git-utils",
      "version": "2.4.2"
    },
    {
      "category": "productivity",
      "description": "개인 코딩 습관과 취향을 Hook/Rule로 관리하는 플러그인",
      "keywords": [
        "coding-style",
        "habits",
        "simplify",
        "hook",
        "quality"
      ],
      "name": "coding-style",
      "source": "./plugins/coding-style",
      "version": "0.3.0"
    },
    {
      "category": "productivity",
      "description": "레이어드 아키텍처 기반 에이전트 설계 원칙 가이드 + convention-architect 워크플로우",
      "keywords": [
        "workflow",
        "design-principles",
        "layered-architecture",
        "agent-design",
        "convention-architect",
        "rules-scaffolding"
      ],
      "name": "workflow-guide",
      "source": "./plugins/workflow-guide",
      "strict": false,
      "version": "0.6.0"
    },
    {
      "category": "productivity",
      "description": "세션 분석 기반 워크플로우 제안 - Claude Code 활용 최적화",
      "keywords": [
        "workflow",
        "suggestion",
        "analysis",
        "optimization",
        "session"
      ],
      "name": "suggest-workflow",
      "source": "./plugins/suggest-workflow",
      "version": "2.1.2"
    },
    {
      "category": "automation",
      "description": "이벤트 기반 자율 개발 오케스트레이터 - Issue 분석, PR 리뷰, 자동 머지",
      "keywords": [
        "autodev",
        "monitor",
        "queue",
        "dashboard",
        "automation"
      ],
      "name": "autodev",
      "source": "./plugins/autodev",
      "version": "0.56.0"
    },
    {
      "category": "productivity",
      "description": "Claude Code status line — 컬러, 프로그레스바, 클릭 가능 링크가 포함된 HUD",
      "keywords": [
        "statusline",
        "hud",
        "ui",
        "tui"
      ],
      "name": "hud",
      "source": "./plugins/hud",
      "version": "0.2.0"
    },
    {
      "category": "infrastructure",
      "description": "FIFO 기반 barrier 패턴 — 병렬 background Task 동기화 (턴 소모 없이 전원 완료 대기)",
      "keywords": [
        "barrier",
        "sync",
        "parallel",
        "background",
        "task",
        "fifo",
        "hook"
      ],
      "name": "barrier-sync",
      "source": "./plugins/barrier-sync",
      "version": "0.1.0"
    },
    {
      "category": "devops",
      "description": "OpenClaw Docker 환경 관리 - run.sh CLI + Skill 기반 게이트웨이 제어, 인증 관리, 로그 조회",
      "keywords": [
        "openclaw",
        "docker",
        "gateway",
        "devops",
        "container"
      ],
      "name": "openclaw-docker",
      "source": "./plugins/openclaw-docker",
      "version": "0.2.0"
    },
    {
      "category": "productivity",
      "description": "스펙 설계, 검증, 갭 분석 통합 툴킷 — 대화형 설계, 스펙 품질 검증, LSP 기반 코드 갭 분석",
      "keywords": [
        "spec",
        "design",
        "review",
        "gap",
        "static-analysis",
        "lsp",
        "architecture"
      ],
      "name": "spec-kit",
      "source": "./plugins/spec-kit",
      "version": "0.6.0"
    },
    {
      "category": "automation",
      "description": "CronCreate 기반 자율 개발 루프 — gap 탐지, issue 구현, PR 머지, CI 감시, QA 보강",
      "keywords": [
        "autopilot",
        "automation",
        "cron",
        "github",
        "issue",
        "pr",
        "ci",
        "qa"
      ],
      "name": "github-autopilot",
      "source": "./plugins/github-autopilot",
      "version": "0.28.0"
    },
    {
      "category": "productivity",
      "description": "메인 에이전트가 직접 코드를 편집하지 않고 sub-agent/agent-team/worktree에 위임해 복합 작업을 관리하는 오케스트레이터 패턴 가이드",
      "keywords": [
        "orchestrator",
        "delegation",
        "sub-agent",
        "agent-team",
        "worktree",
        "parallel",
        "workflow"
      ],
      "name": "orchestrator",
      "source": "./plugins/orchestrator",
      "version": "0.2.0"
    }
  ]
}
